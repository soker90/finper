# ── Base de datos para desarrollo local ──────────────────────────────────────
DATABASE_NAME=finper
DATABASE_HOST=127.0.0.1
MONGODB_USER=
MONGODB_PASS=

# URI completa de MongoDB (opcional, sobreescribe DATABASE_HOST/USER/PASS)
# MONGODB=mongodb://root:changeme@127.0.0.1:27017/finper?retryWrites=true&w=majority

# ── Variables adicionales para Docker Compose ────────────────────────────────
# Necesarias para inicializar el contenedor de MongoDB en docker-compose*.yml
DATABASE_ROOT_USERNAME=root
DATABASE_ROOT_PASSWORD=changeme

# ── Autenticación JWT ────────────────────────────────────────────────────────
JWT_SECRET=change_this_secret
SALT_ROUNDS=10

# ── Logging (API) ────────────────────────────────────────────────────────────
GRAFANA_LOGGER_USER=
GRAFANA_LOGGER_PASSWORD=

# ── Compatibilidad con docker-compose actual ─────────────────────────────────
# Los compose del repo interpolan también estas variables
LOKI_USER=
LOKI_PASSWORD=

# ── Ticket bot / finper-bot ──────────────────────────────────────────────────
# Integración externa actual para el módulo de tickets
TICKET_BOT_URL=
TICKET_BOT_API_KEY=

