# ── Base de datos (SQLite) ───────────────────────────────────────────────────
# Uso local (sin Docker): ruta relativa al proceso o absoluta.
DATABASE_FILE=./finper-dev.db

# Uso con Docker Compose: ruta DENTRO del contenedor.
# El volumen finperdb se monta en /home/node/app/data.
# El default del compose es /home/node/app/data/finper.db (raíz del volumen).
# Descomenta y ajusta solo si quieres cambiar el nombre del fichero.
# DATABASE_FILE=/home/node/app/data/finper.db

# ── Autenticación JWT ────────────────────────────────────────────────────────
JWT_SECRET=change_this_secret
SALT_ROUNDS=10

# ── Logging (API) ────────────────────────────────────────────────────────────
GRAFANA_LOGGER_USER=
GRAFANA_LOGGER_PASSWORD=

# ── Compatibilidad con docker-compose actual ─────────────────────────────────
# Los compose del repo interpolan también estas variables
LOKI_USER=
LOKI_PASSWORD=

# ── Ticket bot / finper-bot ──────────────────────────────────────────────────
# Integración externa actual para el módulo de tickets
TICKET_BOT_URL=
TICKET_BOT_API_KEY=

# ── Seguridad y API ──────────────────────────────────────────────────────────
# Permite el registro abierto de usuarios en POST /api/auth/register
# Por defecto está desactivado (false) para evitar registros indeseados.
ALLOW_REGISTRATION=false

# Orígenes CORS adicionales separados por comas (ej: https://midominio.com).
# Nota: localhost y las IPs de red local (192.168.1.x) ya están permitidos
# por defecto sin necesidad de configurarlos aquí.
CORS_EXTRA_ORIGINS=
